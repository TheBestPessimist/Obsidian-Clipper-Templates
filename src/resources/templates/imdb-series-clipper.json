{
	"schemaVersion": "0.1.0",
	"name": "IMDB Series",
	"behavior": "create",
	"noteContentFormat": "\n> [!NOTE] synopsis\n> {{schema:description}}\n\n## Thoughts\n\nREVIEW HERE",
	"properties": [
		{
			"name": "title",
			"value": "{{schema:@TVSeries:name}} ({{schema:datePublished|slice:0,4}})",
			"type": "text"
		},
		{
			"name": "aliases",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "related",
			"value": "[[Film]], [[Series]], [[imdb]],[[Clippings]]",
			"type": "multitext"
		},
		{
			"name": "year",
			"value": "{{schema:datePublished|slice:0,4}}",
			"type": "number"
		},
		{
			"name": "directors",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "writers",
			"value": "{{selector:#__next > main > div > section.ipc-page-background.ipc-page-background--base.sc-358297d7-0.CHcbB > section > div:nth-child(5) > section > section > div.sc-14a487d5-4.bzdlEY > div.sc-14a487d5-6.gilQBG > div.sc-14a487d5-12.grWKim > div.sc-af040695-2.fLTdiX > ul > li:has(> span.ipc-metadata-list-item__label) > div > ul > li|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "actors",
			"value": "{{schema:actor[*].name|slice:0,5|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "Links",
			"value": "{{url}}",
			"type": "multitext"
		},
		{
			"name": "genre",
			"value": "{{schema:@TVSeries:genre|merge:selector:a[href*=\"/interest/\"] span.ipc-chip__text|unique|sort|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "rating",
			"value": "{{selector:[data-testid=\"hero-rating-bar__user-rating__score\"] span|first}}",
			"type": "text"
		},
		{
			"name": "image",
			"value": "{{schema:image}}",
			"type": "text"
		},
		{
			"name": "description",
			"value": "",
			"type": "text"
		},
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		}
	],
	"triggers": [
		"schema:@TVSeries"
	],
	"noteNameFormat": "{{schema:@TVSeries:name}} ({{schema:datePublished|slice:0,4}})",
	"path": "Film"
}
